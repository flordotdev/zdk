#!/bin/bash

if [ -z "$1" ]; then
    echo "Error: Path to Zomboid's folder is required."
    echo "Usage: $0 <path-to-zomboid-folder>"
    exit 1
fi


MOD_HOME="$(cd "$(dirname "$0")" && cd ".." && pwd)"

ZOMBOID_WORKSHOP_FOLDER="$1/Workshop"

echo $MOD_HOME

ln -s "$MOD_HOME/resources" "$ZOMBOID_WORKSHOP_FOLDER/{{mod_id}}"